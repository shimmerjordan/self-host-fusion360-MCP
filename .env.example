# ─────────────────────────────────────────────────────────────────────────────
# self-host-fusion360-mcp — environment configuration (server side)
# Copy to `.env` and adjust. All values are OPTIONAL; sensible defaults apply.
# 复制为 `.env` 并按需修改。所有项都可选，留空则用默认值。
# ─────────────────────────────────────────────────────────────────────────────

# How the MCP server reaches the in-Fusion add-in bridge.
# 服务器如何连到 Fusion 内的加载项桥。
#   - Native (server runs on the same machine as Fusion):  http://127.0.0.1:9000
#   - Docker  (server in a container, Fusion on the host): http://host.docker.internal:9000
FUSION_ADDIN_URL=http://127.0.0.1:9000

# Shared bearer token. Resolution order: FUSION_MCP_TOKEN > FUSION_MCP_TOKEN_FILE > ~/.fusion-mcp/token
# 共享令牌。解析顺序：FUSION_MCP_TOKEN > FUSION_MCP_TOKEN_FILE > ~/.fusion-mcp/token
# In Docker you typically paste the host token here (see docs/TROUBLESHOOTING).
# FUSION_MCP_TOKEN=
# FUSION_MCP_TOKEN_FILE=

# Request timeout (seconds) for calls forwarded to Fusion. 转发到 Fusion 的请求超时（秒）。
FUSION_MCP_TIMEOUT=30

# Transport: stdio (Claude Desktop/Code) or http (Docker/remote). 传输方式。
FUSION_MCP_TRANSPORT=stdio

# streamable-http bind (only used when FUSION_MCP_TRANSPORT=http). HTTP 传输的监听地址。
FUSION_MCP_HTTP_HOST=0.0.0.0
FUSION_MCP_HTTP_PORT=8765

# DANGER: enable the arbitrary-Python `run_script` tool. Off by default. 危险：开启任意代码执行工具，默认关闭。
FUSION_MCP_ALLOW_ARBITRARY_CODE=0

# Run without Fusion — returns synthetic results (for testing/CI/demo). 无 Fusion 的模拟模式。
FUSION_MCP_MOCK=0

# Log level (DEBUG/INFO/WARNING/ERROR). Logs always go to stderr. 日志级别（始终输出到 stderr）。
FUSION_MCP_LOG_LEVEL=INFO
